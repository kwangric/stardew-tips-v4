---
layout: base.liquid
title: Crops
---

<h1>Crops</h1>

{% for crop in crops %}
	<div>
		<h2>{{ crop.name }}</h2>

		<p><strong>ID:</strong> {{ crop.id }}</p>
		<p><strong>Type:</strong> {{ crop.type }}</p>

		<p><strong>Seasons:</strong>
			{% for season in crop.seasons %}
				{{ season }}{% unless forloop.last %}, {% endunless %}
			{% endfor %}
		</p>

		<p><strong>Sell Price:</strong> {{ crop.sellPrice }}g</p>
		<p><strong>Grow Time:</strong> {{ crop.growDays }} days</p>

		{% if crop.regrowthDays %}
			<p><strong>Regrowth:</strong> {{ crop.regrowthDays }} days</p>
		{% endif %}

		{% if crop.yield %}
			<p><strong>Yield:</strong> {{ crop.yield }}</p>
		{% endif %}

		{% if crop.isTrellis %}
			<p><strong>Trellis:</strong> Yes</p>
		{% endif %}

		<p><strong>Seeds:</strong>
			{% if crop.seedSources.size > 0 %}
				{% for source in crop.seedSources %}
					{{ source.name }} ({{ source.price }}g){% unless forloop.last %}, {% endunless %}
				{% endfor %}
			{% else %}
				Not sold in shops
			{% endif %}
		</p>

		{% if crop.experience %}
			<p><strong>XP:</strong> {{ crop.experience }}</p>
		{% endif %}

		{% if crop.note %}
			<p><strong>Note:</strong> {{ crop.note }}</p>
		{% endif %}

		{% if crop.description %}
			<p>{{ crop.description }}</p>
		{% endif %}

		<hr>
	</div>
{% endfor %}